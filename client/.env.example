# ------------------------------------------------------------------
# Frontend environment variables (copy this file to `.env`).
# In Vite, only variables starting with VITE_ are exposed to the browser.
# ------------------------------------------------------------------

# Base URL of the backend API.
# Local dev: the Express server from /server.
# Production: your deployed backend URL (e.g. https://your-app.onrender.com)
VITE_API_URL=http://localhost:5000
