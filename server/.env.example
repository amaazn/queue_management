# ------------------------------------------------------------------
# Backend environment variables (copy this file to `.env` and fill in)
# ------------------------------------------------------------------

# Port the Express server listens on (local dev). Render/Railway inject their own PORT.
PORT=5000

# MongoDB Atlas connection string.
# Atlas -> Cluster -> Connect -> Drivers -> copy the string.
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/queue_management?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign JWTs. Use a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# How long a login token stays valid.
JWT_EXPIRES_IN=7d

# The URL of the deployed frontend, used to configure CORS.
# Local dev default is the Vite server below.
CLIENT_URL=http://localhost:5173

# Default manager account created by `npm run seed`.
SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Queue Manager
